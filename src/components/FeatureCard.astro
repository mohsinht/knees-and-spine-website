---
interface Props {
  title: string;
  description: string;
  icon?: string;
}
const { title, description, icon = '✦' } = Astro.props;
---

<article class="rounded-[var(--radius-card)] bg-white/70 p-6">
  <span class="text-2xl text-accent" aria-hidden="true">{icon}</span><h3 class="mt-5 font-bold">
    {title}
  </h3><p class="prose-copy mt-2 text-sm">{description}</p>
</article>
