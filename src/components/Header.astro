---
import Container from './Container.astro';
import Button from './Button.astro';
import ResponsiveImage from './ResponsiveImage.astro';
import { clinic } from '@/data/clinic';
import { navItems } from '@/data/content';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-30 border-b border-line/70 bg-cream/95 backdrop-blur">
  <Container
    ><div class="flex min-h-[76px] items-center justify-between gap-5">
      <a href="/" class="flex items-center" aria-label={`${clinic.name} home`}>
        <ResponsiveImage
          src="/brand/logo-icon-128.png"
          width={128}
          height={128}
          class="h-10 w-10 sm:hidden"
          alt=""
          loading="eager"
        />
        <ResponsiveImage
          src="/brand/logo-full-640.png"
          width={640}
          height={178}
          class="hidden h-11 w-auto sm:block"
          alt={clinic.name}
          loading="eager"
        />
      </a><nav class="hidden items-center gap-7 md:flex" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a
              class={`text-sm font-semibold transition-colors hover:text-primary ${currentPath === item.href ? 'text-primary' : 'text-ink'}`}
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </nav><div class="flex items-center gap-2">
        <a class="hidden text-sm font-bold text-primary lg:block" href={clinic.phone.href}
          >{clinic.phone.display}</a
        ><Button href="/contact" class="hidden sm:inline-flex">Book an appointment</Button><button
          class="mobile-toggle inline-flex h-11 w-11 items-center justify-center rounded-[var(--radius-control)] border border-line text-xl md:hidden"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu">☰</button
        >
      </div>
    </div><nav
      id="mobile-menu"
      class="mobile-menu hidden border-t border-line py-4 md:hidden"
      aria-label="Mobile navigation"
    >
      {
        navItems.map((item) => (
          <a class="block rounded-lg px-3 py-3 text-sm font-bold hover:bg-mint" href={item.href}>
            {item.label}
          </a>
        ))
      }<Button
        href={clinic.whatsapp.bookingHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 w-full">Book on WhatsApp</Button
      >
    </nav></Container
  >
</header>
<script>
  const toggle = document.querySelector<HTMLButtonElement>('.mobile-toggle');
  const menu = document.querySelector<HTMLElement>('#mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    menu?.classList.toggle('hidden', open);
  });
</script>
