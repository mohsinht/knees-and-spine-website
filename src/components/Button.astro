---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'light';
  class?: string;
  target?: string;
  rel?: string;
}
const { href, variant = 'primary', class: className = '', target, rel } = Astro.props;
const styles = {
  primary: 'bg-primary text-white hover:bg-primary-dark',
  secondary: 'border border-primary text-primary hover:bg-mint',
  light: 'bg-white text-primary hover:bg-mint',
};
---

{
  href ? (
    <a
      href={href}
      target={target}
      rel={rel}
      class={`inline-flex min-h-12 items-center justify-center rounded-full px-6 text-sm font-bold transition-colors ${styles[variant]} ${className}`}
    >
      <slot />
    </a>
  ) : (
    <button
      class={`inline-flex min-h-12 items-center justify-center rounded-full px-6 text-sm font-bold transition-colors ${styles[variant]} ${className}`}
    >
      <slot />
    </button>
  )
}
