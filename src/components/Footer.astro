---
import Container from './Container.astro';
import ResponsiveImage from './ResponsiveImage.astro';
import { clinic, physiotherapist } from '@/data/clinic';
import { navItems } from '@/data/content';
---

<footer class="border-t border-line bg-primary py-12 text-white">
  <Container
    ><div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a href="/" class="inline-block"
          ><ResponsiveImage
            src="/brand/logo-wordmark-white.png"
            width={1200}
            height={272}
            class="h-12 w-auto"
            alt={clinic.name}
          /></a
        ><p class="mt-4 max-w-sm text-sm leading-relaxed text-white/75">
          Physiotherapy and rehabilitation care focused on movement, strength, mobility, and
          long-term wellbeing.
        </p><p class="mt-6 text-sm text-white/65">
          Led by {physiotherapist.name}, {physiotherapist.credential}
        </p>
      </div><div>
        <h2 class="font-bold">Explore</h2><div class="mt-4 grid gap-3">
          {
            navItems.map((item) => (
              <a class="text-sm text-white/75 hover:text-white" href={item.href}>
                {item.label}
              </a>
            ))
          }<a class="text-sm text-white/75 hover:text-white" href="/privacy">Privacy policy</a>
        </div>
      </div><div>
        <h2 class="font-bold">Contact</h2><div class="mt-4 grid gap-2 text-sm">
          <a class="font-bold text-white" href={clinic.phone.href}>Call: {clinic.phone.display}</a
          ><a
            class="font-bold text-white"
            href={clinic.whatsapp.bookingHref}
            target="_blank"
            rel="noopener noreferrer">WhatsApp: {clinic.whatsapp.display}</a
          ><a class="font-bold text-white" href={`mailto:${clinic.email}`}>Email: {clinic.email}</a>
        </div>
        <div class="mt-5 flex gap-4">
          <a
            class="text-sm font-semibold text-white/75 hover:text-white"
            href={clinic.social.instagram.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Knees & Spine on Instagram">Instagram</a
          ><a
            class="text-sm font-semibold text-white/75 hover:text-white"
            href={clinic.social.facebook.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Knees & Spine on Facebook">Facebook</a
          >
        </div>
      </div>
    </div><div class="mt-12 border-t border-white/20 pt-6 text-xs text-white/60">
      © {new Date().getFullYear()}
      {clinic.name}. Information on this website is educational and not a substitute for medical
      advice.
    </div></Container
  >
</footer>
