---
import Container from './Container.astro';
import { clinic, physiotherapist } from '@/data/clinic';
import { navItems } from '@/data/content';
---

<footer class="border-t border-line bg-surface py-12">
  <Container
    ><div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a href="/" class="display text-2xl font-semibold"
          >Knees <span class="text-accent">&amp;</span> Spine</a
        ><p class="prose-copy mt-4 max-w-sm text-sm">
          Thoughtful physiotherapy for stronger, more confident everyday movement.
        </p><p class="mt-6 text-sm text-muted">
          Led by {physiotherapist.name}, {physiotherapist.credential}
        </p>
      </div><div>
        <h2 class="font-bold">Explore</h2><div class="mt-4 grid gap-3">
          {
            navItems.map((item) => (
              <a class="text-sm text-muted hover:text-primary" href={item.href}>
                {item.label}
              </a>
            ))
          }<a class="text-sm text-muted hover:text-primary" href="/privacy">Privacy policy</a>
        </div>
      </div><div>
        <h2 class="font-bold">Visit us</h2><p class="prose-copy mt-4 text-sm">{clinic.address}</p><p
          class="mt-3 text-sm text-muted"
        >
          {clinic.hours}
        </p><a
          class="mt-4 inline-block text-sm font-bold text-primary"
          href={`tel:${clinic.phone.replaceAll(' ', '')}`}>{clinic.phone}</a
        >
      </div>
    </div><div class="mt-12 border-t border-line pt-6 text-xs text-muted">
      © {new Date().getFullYear()}
      {clinic.name}. Information on this website is educational and not a substitute for medical
      advice.
    </div></Container
  >
</footer>
