---
import Container from './Container.astro';
import ResponsiveImage from './ResponsiveImage.astro';
import { clinic, physiotherapist } from '@/data/clinic';
import { navItems } from '@/data/content';
---

<footer class="border-t border-line bg-primary py-12 text-white">
  <Container
    ><div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a href="/" class="inline-block"
          ><ResponsiveImage
            src="/brand/logo-full-white.png"
            width={640}
            height={178}
            class="h-11 w-auto"
            alt={clinic.name}
          /></a
        ><p class="mt-4 max-w-sm text-sm leading-relaxed text-white/75">
          Thoughtful physiotherapy for stronger, more confident everyday movement.
        </p><p class="mt-6 text-sm text-white/65">
          Led by {physiotherapist.name}, {physiotherapist.credential}
        </p>
      </div><div>
        <h2 class="font-bold">Explore</h2><div class="mt-4 grid gap-3">
          {
            navItems.map((item) => (
              <a class="text-sm text-white/75 hover:text-white" href={item.href}>
                {item.label}
              </a>
            ))
          }<a class="text-sm text-white/75 hover:text-white" href="/privacy">Privacy policy</a>
        </div>
      </div><div>
        <h2 class="font-bold">Visit us</h2><p class="mt-4 text-sm leading-relaxed text-white/75">
          {clinic.address}
        </p><p class="mt-3 text-sm text-white/65">
          {clinic.hours}
        </p><a
          class="mt-4 inline-block text-sm font-bold text-accent"
          href={`tel:${clinic.phone.replaceAll(' ', '')}`}>{clinic.phone}</a
        >
      </div>
    </div><div class="mt-12 border-t border-white/20 pt-6 text-xs text-white/60">
      © {new Date().getFullYear()}
      {clinic.name}. Information on this website is educational and not a substitute for medical
      advice.
    </div></Container
  >
</footer>
