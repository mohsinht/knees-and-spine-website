---
import Container from './Container.astro';
import ResponsiveImage from './ResponsiveImage.astro';
import KneeSpineMark from './graphics/KneeSpineMark.astro';
import { Camera, CalendarCheck, Mail, MapPin, MessageCircle, Phone, ThumbsUp } from '@lucide/astro';
import { clinic, physiotherapist } from '@/data/clinic';
import { navItems } from '@/data/content';
---

<footer
  class="relative overflow-hidden border-t border-line bg-primary py-12 pb-24 text-white sm:py-16 sm:pb-16"
>
  <KneeSpineMark
    variant="white"
    class="pointer-events-none absolute -right-16 bottom-4 hidden h-[25rem] w-auto opacity-[0.06] xl:block"
  />
  <Container
    ><div
      class="relative z-10 grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.45fr_.75fr_1.1fr_.8fr] lg:gap-8"
    >
      <div class="max-w-sm">
        <a href="/" class="inline-block"
          ><ResponsiveImage
            src="/brand/logo-wordmark-white.png"
            width={1200}
            height={272}
            class="h-12 w-auto"
            alt={clinic.name}
          /></a
        ><p class="mt-4 max-w-sm text-sm leading-relaxed text-white/75">
          Physiotherapy and rehabilitation care focused on movement, strength, mobility, and
          long-term wellbeing.
        </p><p class="mt-6 text-sm text-white/65">
          Led by {physiotherapist.name}, {physiotherapist.credential}
        </p>
      </div><div>
        <h2 class="text-sm font-bold uppercase tracking-[.14em] text-[var(--color-brand-teal-300)]">
          Explore
        </h2><div class="mt-5 grid gap-3">
          {
            navItems.map((item) => (
              <a
                class="min-h-6 text-sm text-white/75 transition-colors hover:text-[var(--color-brand-teal-300)]"
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }<a
            class="min-h-6 text-sm text-white/75 transition-colors hover:text-[var(--color-brand-teal-300)]"
            href="/privacy">Privacy Policy</a
          >
        </div>
      </div><div>
        <h2 class="text-sm font-bold uppercase tracking-[.14em] text-[var(--color-brand-teal-300)]">
          Contact
        </h2><div class="mt-5 grid gap-2 text-sm">
          <a
            class="flex min-h-11 items-center gap-3 rounded-xl px-2 text-white/80 transition-colors hover:bg-white/5 hover:text-[var(--color-brand-teal-300)]"
            href={clinic.phone.href}
            ><Phone class="h-4 w-4 shrink-0" aria-hidden="true" /><span
              >Call: {clinic.phone.display}</span
            ></a
          ><a
            class="flex min-h-11 items-center gap-3 rounded-xl px-2 text-white/80 transition-colors hover:bg-white/5 hover:text-[var(--color-brand-teal-300)]"
            href={clinic.whatsapp.bookingHref}
            target="_blank"
            rel="noopener noreferrer"
            ><MessageCircle class="h-4 w-4 shrink-0" aria-hidden="true" /><span
              >WhatsApp: {clinic.whatsapp.display}</span
            ></a
          ><a
            class="flex min-h-11 items-center gap-3 rounded-xl px-2 text-white/80 transition-colors hover:bg-white/5 hover:text-[var(--color-brand-teal-300)]"
            href={`mailto:${clinic.email}`}
            ><Mail class="h-4 w-4 shrink-0" aria-hidden="true" /><span>{clinic.email}</span></a
          ><p class="flex min-h-11 items-start gap-3 px-2 pt-2 text-white/65">
            <MapPin
              class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-brand-teal-300)]"
              aria-hidden="true"
            /><span>{clinic.address}</span>
          </p>
        </div>
      </div><div>
        <h2 class="text-sm font-bold uppercase tracking-[.14em] text-[var(--color-brand-teal-300)]">
          Connect
        </h2><div class="mt-5 grid gap-2">
          <a
            class="flex min-h-11 items-center gap-3 rounded-xl px-2 text-sm font-semibold text-white/80 transition-colors hover:bg-white/5 hover:text-[var(--color-brand-teal-300)]"
            href={clinic.social.instagram.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Knees & Spine on Instagram"
            ><Camera class="h-4 w-4" aria-hidden="true" />Instagram</a
          ><a
            class="flex min-h-11 items-center gap-3 rounded-xl px-2 text-sm font-semibold text-white/80 transition-colors hover:bg-white/5 hover:text-[var(--color-brand-teal-300)]"
            href={clinic.social.facebook.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Knees & Spine on Facebook"
            ><ThumbsUp class="h-4 w-4" aria-hidden="true" />Facebook</a
          ><a
            class="mt-2 flex min-h-11 items-center gap-3 rounded-xl border border-[var(--color-brand-teal-500)]/45 px-3 text-sm font-bold text-white transition-colors hover:bg-white/5 hover:text-[var(--color-brand-teal-300)]"
            href={clinic.whatsapp.bookingHref}
            target="_blank"
            rel="noopener noreferrer"
            ><CalendarCheck
              class="h-4 w-4 text-[var(--color-brand-teal-300)]"
              aria-hidden="true"
            />Book an appointment</a
          >
        </div>
      </div>
    </div><div
      class="relative z-10 mt-12 flex flex-col gap-3 border-t border-[var(--color-brand-teal-300)]/35 pt-6 text-xs leading-relaxed text-white/60 lg:flex-row lg:items-center lg:justify-between"
    >
      <p>© 2026 {clinic.name}. All rights reserved.</p>
      <p>
        Information on this website is educational and is not a substitute for professional medical
        advice.
      </p>
      <div class="flex items-center gap-4">
        <a class="transition-colors hover:text-[var(--color-brand-teal-300)]" href="/privacy"
          >Privacy Policy</a
        >
        <a class="transition-colors hover:text-[var(--color-brand-teal-300)]" href={clinic.website}
          >kneesandspine.com</a
        >
      </div>
    </div></Container
  >
</footer>
