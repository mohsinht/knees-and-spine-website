---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, intro, align = 'left' } = Astro.props;
---

<div class={`max-w-2xl ${align === 'center' ? 'mx-auto text-center' : ''}`}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="display text-3xl leading-tight text-ink sm:text-4xl">{title}</h2>
  {intro && <p class="prose-copy mt-4 text-base">{intro}</p>}
</div>
