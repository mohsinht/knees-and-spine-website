---
import { clinic } from '@/data/clinic';
const message = encodeURIComponent(
  'Hello, I would like to book a physiotherapy appointment at Knees & Spine Physio Clinic.',
);
---

<a
  class="fixed bottom-5 right-5 z-40 flex min-h-14 items-center gap-2 rounded-full bg-[#25D366] px-5 font-bold text-white shadow-lg transition-transform hover:scale-105"
  href={`https://wa.me/${clinic.whatsapp}?text=${message}`}
  aria-label="Book an appointment on WhatsApp"
  ><span class="text-xl">◌</span><span class="hidden sm:inline">WhatsApp us</span></a
>
