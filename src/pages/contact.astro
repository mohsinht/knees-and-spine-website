---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Button from '@/components/Button.astro';
import { clinic } from '@/data/clinic';
const message = encodeURIComponent(
  'Hello, I would like to book a physiotherapy appointment at Knees & Spine Physio Clinic.',
);
---

<BaseLayout
  title="Contact and appointments | Knees & Spine Lahore"
  description="Contact Knees & Spine Physio Clinic in Canal Garden, Lahore to ask a question or request a physiotherapy appointment."
  ><section class="py-16 sm:py-24">
    <Container
      ><div class="grid gap-12 lg:grid-cols-[.8fr_1.2fr]">
        <div>
          <p class="eyebrow">Contact the clinic</p><h1 class="display mt-4 text-5xl sm:text-6xl">
            Let’s talk about your next step.
          </h1><p class="prose-copy mt-6 text-lg">
            Use the form to share a little about what you need. For the quickest response, message
            us on WhatsApp.
          </p><a
            class="mt-7 inline-flex min-h-12 items-center justify-center rounded-full bg-[#25D366] px-6 text-sm font-bold text-white"
            href={`https://wa.me/${clinic.whatsapp}?text=${message}`}>Message on WhatsApp ↗</a
          ><dl class="mt-12 grid gap-6 text-sm">
            <div>
              <dt class="font-bold">Phone</dt><dd class="prose-copy mt-1">
                <a href={`tel:${clinic.phone.replaceAll(' ', '')}`}>{clinic.phone}</a>
              </dd>
            </div><div>
              <dt class="font-bold">Email</dt><dd class="prose-copy mt-1">
                <a href={`mailto:${clinic.email}`}>{clinic.email}</a>
              </dd>
            </div><div>
              <dt class="font-bold">Address</dt><dd class="prose-copy mt-1">{clinic.address}</dd>
            </div><div>
              <dt class="font-bold">Hours</dt><dd class="prose-copy mt-1">{clinic.hours}</dd>
            </div>
          </dl><a
            class="mt-8 inline-block font-bold text-primary underline decoration-accent decoration-2 underline-offset-8"
            href={clinic.mapsUrl}
            target="_blank"
            rel="noreferrer">Open in Google Maps ↗</a
          >
        </div><div class="rounded-[1.5rem] bg-surface p-6 shadow-[var(--shadow-soft)] sm:p-10">
          <h2 class="display text-3xl">Request an appointment</h2><p
            class="prose-copy mt-2 text-sm"
          >
            This form is ready to connect to a Cloudflare Pages Function or form service.
          </p><form class="mt-8 grid gap-5" action="#" method="post" data-contact-form novalidate>
            <div>
              <label class="text-sm font-bold" for="name"
                >Name <span class="text-primary">*</span></label
              ><input
                class="mt-2 min-h-12 w-full rounded-xl border border-line bg-cream px-4 text-sm"
                id="name"
                name="name"
                autocomplete="name"
                required
              /><p class="mt-1 hidden text-xs font-semibold text-red-700" data-error-for="name">
                Please enter your name.
              </p>
            </div><div>
              <label class="text-sm font-bold" for="phone"
                >Phone <span class="text-primary">*</span></label
              ><input
                class="mt-2 min-h-12 w-full rounded-xl border border-line bg-cream px-4 text-sm"
                id="phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                required
              /><p class="mt-1 hidden text-xs font-semibold text-red-700" data-error-for="phone">
                Please enter a phone number.
              </p>
            </div><div>
              <label class="text-sm font-bold" for="date">Preferred date</label><input
                class="mt-2 min-h-12 w-full rounded-xl border border-line bg-cream px-4 text-sm"
                id="date"
                name="date"
                type="date"
              />
            </div><div>
              <label class="text-sm font-bold" for="concern"
                >Main concern <span class="text-primary">*</span></label
              ><select
                class="mt-2 min-h-12 w-full rounded-xl border border-line bg-cream px-4 text-sm"
                id="concern"
                name="concern"
                required
                ><option value="">Choose an option</option><option>Knee pain</option><option
                  >Back pain</option
                ><option>Neck or shoulder pain</option><option>Mobility or balance</option><option
                  >Other</option
                ></select
              ><p class="mt-1 hidden text-xs font-semibold text-red-700" data-error-for="concern">
                Please choose your main concern.
              </p>
            </div><div>
              <label class="text-sm font-bold" for="message">Message</label><textarea
                class="mt-2 min-h-32 w-full rounded-xl border border-line bg-cream px-4 py-3 text-sm"
                id="message"
                name="message"
                rows="4"></textarea>
            </div><Button>Send request</Button><p
              class="hidden text-sm font-semibold text-primary"
              data-form-success
              role="status"
            >
              Thanks — this demo form is ready to connect to a booking service.
            </p>
          </form>
        </div>
      </div></Container
    >
  </section></BaseLayout
>
<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    let valid = true;
    form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]').forEach((field) => {
      const error = form.querySelector<HTMLElement>(`[data-error-for="${field.name}"]`);
      const invalid = !field.value.trim();
      field.setAttribute('aria-invalid', String(invalid));
      error?.classList.toggle('hidden', !invalid);
      if (invalid) valid = false;
    });
    if (valid) form.querySelector<HTMLElement>('[data-form-success]')?.classList.remove('hidden');
  });
</script>
