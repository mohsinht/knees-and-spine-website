---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { clinic } from '@/data/clinic';
---

<BaseLayout
  title="Contact and appointments | Knees & Spine Lahore"
  description="Contact Knees & Spine Physio Clinic in Canal Garden, Lahore to ask a question or request a physiotherapy appointment."
  ><section class="py-16 sm:py-24">
    <Container
      ><div class="grid gap-12 lg:grid-cols-[.8fr_1.2fr]">
        <div>
          <p class="eyebrow">Contact the clinic</p><h1 class="display mt-4 text-5xl sm:text-6xl">
            Let’s talk about your next step.
          </h1><p class="prose-copy mt-6 text-lg">
            Reach out in the way that feels easiest. WhatsApp is the quickest way to ask a question
            or arrange an appointment.
          </p><div class="mt-7 flex flex-wrap gap-3">
            <a
              class="inline-flex min-h-12 items-center justify-center rounded-full bg-[var(--color-whatsapp)] px-6 text-sm font-bold text-white"
              href={clinic.whatsapp.bookingHref}
              target="_blank"
              rel="noopener noreferrer">Book on WhatsApp ↗</a
            ><a
              class="inline-flex min-h-12 items-center justify-center rounded-full border border-primary px-6 text-sm font-bold text-primary"
              href={clinic.phone.href}>Call the Clinic</a
            >
          </div><a
            class="mt-5 inline-block text-sm font-bold text-primary underline decoration-accent decoration-2 underline-offset-8"
            href={`mailto:${clinic.email}`}>Email Us</a
          ><dl class="mt-12 grid gap-6 text-sm">
            <div>
              <dt class="font-bold">Phone</dt><dd class="prose-copy mt-1">
                <a href={clinic.phone.href}>{clinic.phone.display}</a>
              </dd>
            </div><div>
              <dt class="font-bold">WhatsApp</dt><dd class="prose-copy mt-1">
                <a href={clinic.whatsapp.bookingHref} target="_blank" rel="noopener noreferrer"
                  >{clinic.whatsapp.display}</a
                >
              </dd>
            </div><div>
              <dt class="font-bold">Email</dt><dd class="prose-copy mt-1">
                <a href={`mailto:${clinic.email}`}>{clinic.email}</a>
              </dd>
            </div><div>
              <dt class="font-bold">Clinic location</dt><dd class="prose-copy mt-1">
                {clinic.address}
              </dd>
            </div>
          </dl>
        </div><aside
          class="rounded-[var(--radius-feature)] bg-mint p-6 sm:p-10"
          aria-labelledby="booking-heading"
        >
          <p class="eyebrow">Booking made simple</p><h2
            id="booking-heading"
            class="display mt-3 text-3xl"
          >
            Choose the contact method that suits you.
          </h2><ol class="mt-8 grid gap-6">
            <li class="border-t border-line pt-5">
              <strong>1. Share your concern</strong><p class="prose-copy mt-2 text-sm">
                Let us know what you would like help with and when you would prefer to visit.
              </p>
            </li>
            <li class="border-t border-line pt-5">
              <strong>2. We’ll guide the next step</strong><p class="prose-copy mt-2 text-sm">
                The clinic can help you understand the appropriate appointment option.
              </p>
            </li>
            <li class="border-t border-line pt-5">
              <strong>3. Arrive prepared</strong><p class="prose-copy mt-2 text-sm">
                Bring any relevant reports or prescriptions to help inform your assessment.
              </p>
            </li>
          </ol>
        </aside>
      </div></Container
    >
  </section></BaseLayout
>
