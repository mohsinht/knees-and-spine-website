---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
---

<BaseLayout
  title="Privacy policy | Knees & Spine Physio Clinic"
  description="Privacy policy for Knees & Spine Physio Clinic website visitors."
  ><section class="py-16 sm:py-24">
    <Container
      ><div class="max-w-3xl">
        <p class="eyebrow">Privacy</p><h1 class="display mt-4 text-5xl">
          Your information matters.
        </h1><div class="prose-copy mt-8 space-y-6">
          <p>
            This initial privacy policy is a clear placeholder for v0. It should be reviewed and
            updated with the clinic’s legal details before the website collects or stores personal
            information.
          </p><h2 class="text-xl font-bold text-ink">Information you share</h2><p>
            The contact form is currently UI-only and does not submit information. When a form
            service or Cloudflare Pages Function is connected, this section should explain what is
            collected, why it is used, and how long it is retained.
          </p><h2 class="text-xl font-bold text-ink">Contact</h2><p>
            For privacy questions, please use the contact details listed on the Contact page.
          </p>
        </div>
      </div></Container
    >
  </section></BaseLayout
>
