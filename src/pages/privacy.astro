---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
---

<BaseLayout
  title="Privacy policy | Knees & Spine Physio Clinic"
  description="Privacy policy for Knees & Spine Physio Clinic website visitors."
  ><section class="py-16 sm:py-24">
    <Container
      ><div class="max-w-3xl">
        <p class="eyebrow">Privacy</p><h1 class="display mt-4 text-5xl">
          Your information matters.
        </h1><div class="prose-copy mt-8 space-y-6">
          <p>
            We respect the privacy of everyone who visits this website. This website does not use a
            booking form or ask you to create an account.
          </p><h2 class="text-xl font-bold text-ink">When you contact us</h2><p>
            If you contact the clinic by WhatsApp, phone, or email, the information you choose to
            share is used only to respond to your enquiry and help arrange care.
          </p><h2 class="text-xl font-bold text-ink">Third-party services</h2><p>
            WhatsApp, email providers, and social networks have their own privacy practices. We
            encourage you to review those policies before using their services.
          </p><h2 class="text-xl font-bold text-ink">Contact</h2><p>
            For privacy questions, please use the contact details listed on the Contact page.
          </p>
        </div>
      </div></Container
    >
  </section></BaseLayout
>
