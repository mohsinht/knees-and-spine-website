---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import AppointmentCTA from '@/components/AppointmentCTA.astro';
import { clinic, physiotherapist } from '@/data/clinic';
---

<BaseLayout
  title="About the clinic | Knees & Spine Physio Clinic"
  description="Meet Dr. Laiba Arshad and learn about the patient-first approach at Knees & Spine Physio Clinic in Canal Garden, Lahore."
  ><section class="bg-primary py-20 text-white sm:py-28">
    <Container
      ><div class="max-w-3xl">
        <p class="eyebrow text-[var(--color-brand-teal-300)]">About Knees &amp; Spine</p><h1
          class="display mt-4 max-w-4xl text-5xl sm:text-6xl"
        >
          Good care starts with being heard.
        </h1><p class="mt-7 max-w-2xl text-lg leading-relaxed text-white/80">
          A welcoming clinic for people who want clearer answers, practical support, and a steady
          way forward.
        </p>
      </div></Container
    >
  </section><section class="py-20 sm:py-28">
    <Container
      ><div class="grid gap-12 lg:grid-cols-2">
        <SectionHeading
          eyebrow="Your clinician"
          title={`${physiotherapist.name}, ${physiotherapist.credential}`}
          intro="As lead physiotherapist, Dr. Laiba Arshad is focused on making rehabilitation feel clear, respectful, and relevant to daily life."
        /><div class="rounded-[var(--radius-feature)] bg-mint p-8">
          <p class="display text-3xl">
            “The goal is to help you feel more capable in the movements that matter to you.”
          </p><p class="prose-copy mt-6 text-sm">
            Every appointment is shaped around your current ability, the activities that matter to
            you, and a clear plan for moving forward.
          </p>
        </div>
      </div></Container
    >
  </section><section class="bg-surface py-20 sm:py-28">
    <Container
      ><SectionHeading
        eyebrow="Our approach"
        title="A clinic built around progress you can understand."
        align="center"
      /><div class="mt-10 grid gap-4 md:grid-cols-3">
        <FeatureCard
          title="Personalised"
          description="Your care plan starts with your needs, not a template."
          icon="care"
        /><FeatureCard
          title="Practical"
          description="We focus on steps that can carry into your home and routine."
          icon="assessment"
        /><FeatureCard
          title="Collaborative"
          description="You are part of decisions about your treatment and progress."
          icon="progress"
        />
      </div></Container
    >
  </section><section class="py-20">
    <Container
      ><div class="rounded-[var(--radius-feature)] border border-line p-8 sm:p-12">
        <p class="eyebrow">Find us in Lahore</p><h2 class="display mt-3 text-3xl">
          A calm space in Canal Garden.
        </h2><p class="prose-copy mt-4 max-w-xl">
          {clinic.address}.
        </p>
      </div></Container
    >
  </section><AppointmentCTA /></BaseLayout
>
